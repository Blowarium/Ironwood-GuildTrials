# Neon Postgres connection string (free tier works great with Vercel).
# Create at https://neon.tech or via Vercel → Storage → Neon.
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Staff role passwords — required in production to prevent spoofing Leader/Officer.
# In local dev, defaults are dev-leader / dev-officer if unset.
GUILD_LEADER_PASSWORD=change-me-leader
GUILD_OFFICER_PASSWORD=change-me-officer

# Secret used to sign staff session tokens (use a long random string in production).
STAFF_AUTH_SECRET=change-me-to-a-long-random-string
